{
    "$schema": "https://schema.tauri.app/config/2",
    "app": {
        "security": {
            "csp": null
        },
        "windows": []
    },
    "build": {
        "beforeBuildCommand": "pnpm build",
        "beforeDevCommand": "pnpm dev",
        "devUrl": "http://localhost:1420",
        "frontendDist": "../build"
    },
    "bundle": {
        "active": true,
        "createUpdaterArtifacts": true,
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "targets": [
            "deb",
            "rpm",
            "nsis",
            "app",
            "dmg"
        ],
        "windows": {
            "nsis": {
                "languages": [
                    "English",
                    "Russian"
                ]
            }
        }
    },
    "identifier": "com.scrybe.live",
    "plugins": {
        "updater": {
            "endpoints": [
                "https://github.com/synthlabs/scrybe/releases/latest/download/latest.json"
            ],
            "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDIwMDJBODMwMUY3MEMzRApSV1E5RFBjQmd5b0FBdk9Vckg1UFB1RlhqQnNhK1A0QlNNdWErNUlrWXhVY0ZORU95akRTc040MAo="
        }
    },
    "productName": "Scrybe",
    "version": "0.2.15"
}